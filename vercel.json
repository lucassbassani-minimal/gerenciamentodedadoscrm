{
  "rewrites": [
    { "source": "/", "destination": "/dashboard-crm.html" }
  ],
  "functions": {
    "api/cron/revenue.py":        { "maxDuration": 300 },
    "api/cron/sessions.py":       { "maxDuration": 300 },
    "api/cron/email_flow.py":     { "maxDuration": 300 },
    "api/cron/email_campaign.py": { "maxDuration": 300 },
    "api/cron/forms.py":          { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/cron/revenue",        "schedule": "*/35 * * * *" },
    { "path": "/api/cron/sessions",       "schedule": "10 * * * *"  },
    { "path": "/api/cron/email_flow",     "schedule": "0 7 * * *"   },
    { "path": "/api/cron/email_campaign", "schedule": "30 3 * * *"  },
    { "path": "/api/cron/forms",          "schedule": "0 9 * * *"   }
  ]
}
