# =============================================================================
# Dashboard CRM · Minimal Club · Mapeamento de credenciais e endpoints
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# `.env` está no .gitignore — NUNCA commite credenciais.
# =============================================================================

# -----------------------------------------------------------------------------
# AMBIENTE / APP
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=dashboard-crm-minimal
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt-BR
APP_CURRENCY=BRL

# Porta do back-end (quando for construir a API que serve o dashboard)
APP_PORT=3000

# URL pública do front-end (atualizar quando publicar)
APP_PUBLIC_URL=http://localhost:3000


# =============================================================================
# SUPABASE — Base de dados central (a construir)
# =============================================================================
# Obter em: https://supabase.com/dashboard/project/<PROJECT>/settings/api
# Documentação: https://supabase.com/docs/guides/api
# -----------------------------------------------------------------------------
# Token secreto para proteger o endpoint /sync do Railway
# Gere um valor longo e aleatório: python -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_SECRET_TOKEN=

# Vercel Cron Jobs — protege os endpoints /api/cron/* de chamadas externas não autorizadas
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Configurar também no painel da Vercel: Settings → Environment Variables
CRON_SECRET=

# Alertas por e-mail quando um cron falha
# ALERT_SMTP_USER     → seu e-mail Google Workspace (daniel.magalhaes@minimalclub.com.br)
# ALERT_SMTP_PASSWORD → senha de app (Google Conta → Segurança → Senhas de app)
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres


# =============================================================================
# SHOPIFY — Orders, Customers, Faturamento, Atribuição via UTM, 1ª/Recompra
# =============================================================================
# Obter em: Shopify Admin → Settings → Apps → Develop apps → Configure Admin API
# Documentação: https://shopify.dev/docs/api/admin
# Escopo necessário: read_orders, read_customers, read_products, read_analytics
# -----------------------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=minimalclub.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WEBHOOK_SECRET=


# =============================================================================
# KLAVIYO — E-mail (Fluxo, Campanha), Popups/Forms, Captação de Leads,
#           Saúde da Base (entregabilidade, bounce, spam, opt-out)
# =============================================================================
# Obter em: Klaviyo → Account → Settings → API Keys
# Documentação: https://developers.klaviyo.com/en/reference/api_overview
# Escopo: read profiles, lists, segments, campaigns, flows, forms, metrics, events
# -----------------------------------------------------------------------------
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_PUBLIC_API_KEY=
KLAVIYO_COMPANY_ID=
KLAVIYO_API_REVISION=2024-10-15

# Segmentos críticos (preencher com IDs após criar no Klaviyo)
KLAVIYO_SEGMENT_ENGAGED_90D=
KLAVIYO_SEGMENT_WPP_INSCRITOS=
# Listas de formulários e popups
KLAVIYO_FORMS_TRACKED_IDS=


# =============================================================================
# VEKTA + n8n — WhatsApp (Fluxo + Campanha)
# Disparos, respostas, destravar objeção, leads ao comercial, retenção IA
# =============================================================================
# Vekta: solicitar credencial ao time / fornecedor
# n8n: instância interna / cloud
# -----------------------------------------------------------------------------
VEKTA_API_BASE_URL=
VEKTA_API_KEY=
VEKTA_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# CHATFLUX — WhatsApp (Welcome parcial + Carrinho Abandonado)
# Solicitar token ao time da ChatFlux
# -----------------------------------------------------------------------------
CHATFLUX_API_BASE_URL=https://minimal-disparos-production-b9a1.up.railway.app
CHATFLUX_API_TOKEN=

N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_URL_CRM=
N8N_WEBHOOK_SECRET=


# =============================================================================
# SENDFLOW — Comunidade WhatsApp
# Participantes, entradas, saídas, disparos
# =============================================================================
# Documentação: solicitar ao fornecedor
# -----------------------------------------------------------------------------
SENDFLOW_API_BASE_URL=
SENDFLOW_API_KEY=
SENDFLOW_API_KEY_2=
SENDFLOW_WORKSPACE_ID=
SENDFLOW_COMMUNITY_ID=


# =============================================================================
# HUBSPOT — Fonte ATUAL de inscritos WhatsApp Fluxo
# (será descontinuada após migração para Klaviyo)
# =============================================================================
# Obter em: HubSpot → Settings → Integrations → Private Apps
# Documentação: https://developers.hubspot.com/docs/api/overview
# Escopo: crm.objects.contacts.read, crm.lists.read
# -----------------------------------------------------------------------------
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_LIST_WPP_FLUXO_INSCRITOS=


# =============================================================================
# GOOGLE ANALYTICS 4 / LOOKER — Sessões, ATC, BCO, atribuição via UTM
# =============================================================================
# Opção A: GA4 Data API (service account)
# Documentação: https://developers.google.com/analytics/devguides/reporting/data/v1
# Habilitar API no Google Cloud Console + criar service account + JSON
# -----------------------------------------------------------------------------
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_JSON_PATH=./credentials/ga4-service-account.json

# Opção B: BigQuery export (recomendado para volume alto)
GCP_PROJECT_ID=
GCP_BIGQUERY_DATASET=
GCP_BIGQUERY_SERVICE_ACCOUNT_JSON_PATH=./credentials/bigquery-service-account.json

# Google Sheets — CSV público com sessões/ATC/BCO exportados do BigQuery
# Formato: URL de publicação da aba específica com gid=<ID_DA_ABA>
# Exemplo: https://docs.google.com/spreadsheets/d/e/<ID>/pub?gid=<GID>&single=true&output=csv
GOOGLE_SHEETS_CSV_URL=

# Google Sheets — exportação horária de leads_webhook (Vekta → Sheets)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=credentials/google-service-account.json
GOOGLE_SHEETS_LEADS_SPREADSHEET_ID=

# WPP Fluxo — CSV público com inscritos por Alia Campanha (Vekta/Alia)
WPP_FLOW_SUBSCRIBERS_CSV_URL=

# Looker Studio (opcional — se for puxar dataset já tratado)
LOOKER_STUDIO_REPORT_ID=


# =============================================================================
# META BUSINESS / WHATSAPP BUSINESS PLATFORM — FORA DO ESCOPO V1
# (Fase 2: saúde do número, quality rating, delivery, blocks)
# =============================================================================
# Obter em: developers.facebook.com → Apps → System User Access Token
# -----------------------------------------------------------------------------
META_ACCESS_TOKEN=
META_BUSINESS_ID=
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_API_VERSION=v21.0


# =============================================================================
# UTM / ATRIBUIÇÃO — Configuração de canais
# =============================================================================
# UTMs padronizadas que mapeiam para os 5 canais CRM (last-click)
# -----------------------------------------------------------------------------
UTM_CHANNEL_EMAIL_FLUXO=email:flow
UTM_CHANNEL_EMAIL_CAMPANHA=email:campaign
UTM_CHANNEL_WPP_FLUXO=whatsapp:flow
UTM_CHANNEL_WPP_CAMPANHA=whatsapp:campaign
UTM_CHANNEL_COMUNIDADE=whatsapp:community


# =============================================================================
# METAS MENSAIS — Input manual
# =============================================================================
# Em V1, alimentar via planilha → tabela `metas_mensais` no Supabase
# Quando construir UI de gestão, pode ser editável por admins
# -----------------------------------------------------------------------------
META_FONTE=planilha_manual
META_PLANILHA_GOOGLE_SHEETS_ID=


# =============================================================================
# OBSERVABILIDADE (opcional, recomendado quando o back-end existir)
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info
